{
  "name": "shell-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Shell Chain",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "shell-chain",
    "sdk",
    "viem",
    "typescript",
    "pq"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShellDAO/shell-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/ShellDAO/shell-sdk/issues"
  },
  "homepage": "https://github.com/ShellDAO/shell-sdk#readme",
  "dependencies": {
    "@noble/ciphers": "^2.1.1",
    "@noble/hashes": "^1.8.0",
    "@noble/post-quantum": "^0.6.0",
    "@scure/base": "^1.2.6",
    "hash-wasm": "^4.12.0",
    "viem": "^2.39.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
